{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recycled Part",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "device_slug",
    "part_name",
    "species",
    "genus",
    "mounting",
    "value",
    "keywords",
    "description",
    "kicad_symbol",
    "kicad_footprint",
    "datasheet_url",
    "source_url",
    "quantity",
    "designators",
    "part_aliases",
    "confidence"
  ],
  "properties": {
    "device_slug": {
      "type": "string",
      "minLength": 3
    },
    "part_name": {
      "type": "string",
      "minLength": 1
    },
    "species": {
      "type": "string",
      "minLength": 1
    },
    "genus": {
      "type": "string",
      "minLength": 1
    },
    "mounting": {
      "type": "string",
      "enum": ["SMD", "THT", ""]
    },
    "value": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "kicad_symbol": {
      "type": "string"
    },
    "kicad_footprint": {
      "type": "string"
    },
    "datasheet_url": {
      "type": "string"
    },
    "source_url": {
      "type": "string"
    },
    "quantity": {
      "type": "integer",
      "minimum": 0
    },
    "designators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "part_aliases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
