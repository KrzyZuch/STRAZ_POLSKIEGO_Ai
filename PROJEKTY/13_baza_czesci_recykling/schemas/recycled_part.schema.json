{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Recycled Device Part Link",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "device_slug",
    "part_slug",
    "source_url",
    "quantity",
    "designators",
    "confidence"
  ],
  "properties": {
    "device_slug": {
      "type": "string",
      "minLength": 3
    },
    "part_slug": {
      "type": "string",
      "minLength": 3
    },
    "source_url": {
      "type": "string"
    },
    "quantity": {
      "type": "integer",
      "minimum": 0
    },
    "designators": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stock_location": {
      "type": "string"
    },
    "evidence_url": {
      "type": "string"
    },
    "evidence_timecode": {
      "type": ["number", "null"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    }
  }
}
